						"value": "[parameters('LS_REST_ADLS_Parquet_properties_typeProperties_url')]"
					},
					"LS_RestResource_properties_typeProperties_url": {
						"value": "[parameters('LS_RestResource_properties_typeProperties_url')]"
					},
					"LS_SQLSERVER_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLSERVER_properties_typeProperties_server')]"
					},
					"LS_SQLSERVER_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLSERVER_properties_typeProperties_database')]"
					},
					"LS_SQLSERVER_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLSERVER_properties_typeProperties_userName')]"
					},
					"LS_SQLSERVER_PARQUET_ADLS_properties_typeProperties_url": {
						"value": "[parameters('LS_SQLSERVER_PARQUET_ADLS_properties_typeProperties_url')]"
					},
					"LS_SqlServerTable1_properties_typeProperties_server": {
						"value": "[parameters('LS_SqlServerTable1_properties_typeProperties_server')]"
					},
					"LS_SqlServerTable1_properties_typeProperties_database": {
						"value": "[parameters('LS_SqlServerTable1_properties_typeProperties_database')]"
					},
					"LS_SqlServerTable1_properties_typeProperties_userName": {
						"value": "[parameters('LS_SqlServerTable1_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}