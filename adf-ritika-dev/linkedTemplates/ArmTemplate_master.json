					},
					"LS_REST_ADLS_Parquet_accountKey": {
						"value": "[parameters('LS_REST_ADLS_Parquet_accountKey')]"
					},
					"LS_SQLSERVER_password": {
						"value": "[parameters('LS_SQLSERVER_password')]"
					},
					"LS_SQLSERVER_PARQUET_ADLS_accountKey": {
						"value": "[parameters('LS_SQLSERVER_PARQUET_ADLS_accountKey')]"
					},
					"LS_SqlServerTable1_password": {
